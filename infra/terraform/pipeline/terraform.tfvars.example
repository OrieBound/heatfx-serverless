# Copy to terraform.tfvars (gitignored) or use:
#   terraform apply -var-file=terraform.tfvars
#
# Do not commit real ARNs or account-specific values to a public repo.

aws_region  = "us-east-1"
environment = "prod"

github_repository_id = "OWNER/REPO-NAME"
github_branch        = "main"

# Prefer reusing one GitHub connection for every pipeline (CodeConnections or legacy codestar-connections ARN both work):
use_existing_connection = true
connection_arn          = "arn:aws:codeconnections:REGION:ACCOUNT_ID:connection/CONNECTION_UUID"

# Option B — let Terraform create a new connection (name heatfx-terraform-<environment>), then complete OAuth in AWS:
# use_existing_connection = false
# connection_arn          = ""

cognito_domain_prefix = "heatfx-your-unique-prefix-prod"

app_callback_urls = [
  "http://localhost:3000/auth/callback",
]
app_logout_urls = [
  "http://localhost:3000/",
]

cors_allow_origins = [
  "https://YOUR_DIST.cloudfront.net",
  "http://localhost:3000",
]
