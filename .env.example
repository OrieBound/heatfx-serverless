# Copy to .env.local and fill from CloudFormation/Terraform outputs (see README + infra/README).

# API Gateway HTTP API base URL (no trailing slash; app calls `${API_URL}/api/...`)
NEXT_PUBLIC_API_URL=https://xxxxxxxx.execute-api.us-east-1.amazonaws.com

# Cognito (Hosted UI domain is typically PREFIX.auth.REGION.amazoncognito.com)
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
# NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_COGNITO_DOMAIN=your-prefix.auth.us-east-1.amazoncognito.com
# NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
